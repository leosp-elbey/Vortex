# ============================================================
# VortexTrips — Environment Variables
# Copy to .env.local and fill in real values for local dev.
# Production values live in Vercel Settings → Environment Variables.
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_NOTIFICATION_EMAIL=
CRON_SECRET=

# ─── Webhook security (Phase 8) ─────────────────────────────
# Public anti-bot token sent by all lead-form pages. Generate any random string.
# This is exposed to the browser — it's a deterrent, not a secret.
NEXT_PUBLIC_FORM_TOKEN=
# Bearer token Bland.ai sends with webhook callbacks. Set this in your Bland webhook config.
BLAND_WEBHOOK_SECRET=

# ─── AI Command Center ──────────────────────────────────────
# OpenRouter is the main AI gateway. Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model selection per task type. Browse models at https://openrouter.ai/models
# Defaults below are reasonable starting points — adjust to your budget/quality tradeoff.
AI_DEFAULT_MODEL=anthropic/claude-haiku-4.5
AI_CHEAP_MODEL=meta-llama/llama-3.3-70b-instruct
AI_MEDIUM_MODEL=anthropic/claude-sonnet-4.6
AI_STRONG_MODEL=anthropic/claude-opus-4-7
AI_CODING_MODEL=anthropic/claude-sonnet-4.6
AI_VERIFIER_MODEL=anthropic/claude-opus-4-7

# Budget guardrails (USD). AI router blocks new jobs when limits are hit.
AI_MONTHLY_BUDGET_LIMIT=75
AI_DAILY_BUDGET_LIMIT=5
AI_REQUIRE_HUMAN_APPROVAL=true

# Anthropic SDK is used directly (not via OpenRouter) by the verifier layer.
ANTHROPIC_API_KEY=

# OpenAI used for DALL-E + GPT image/text generation in content engine.
OPENAI_API_KEY=

# ─── Email + SMS ────────────────────────────────────────────
# Resend handles transactional email (drip sequences, quotes).
RESEND_API_KEY=

# Twilio handles SMS drip. BLOCKED in prod pending A2P TCR approval.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Voice AI ───────────────────────────────────────────────
# Bland.ai triggers a 60-second savings call on lead creation.
BLAND_API_KEY=

# ─── Social posting ─────────────────────────────────────────
# Facebook + Instagram use the same Meta Page Access Token (one token, both vars).
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
NEXT_PUBLIC_FB_APP_ID=
NEXT_PUBLIC_FB_LOGIN_CONFIG_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# YouTube OAuth (refresh token stored in Supabase site_settings, not here).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok posting (credentials present, posting routes not yet implemented).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Twitter/X posting (credentials present, posting routes not yet implemented).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Content generation ─────────────────────────────────────
# Pexels supplies real travel photos (re-hosted in Supabase Storage).
PEXELS_API_KEY=

# HeyGen generates the SBA avatar video (Maya avatar, Hope voice).
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ─── Analytics ──────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── PAUSED — Stripe (membership purchase flow not yet implemented) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
