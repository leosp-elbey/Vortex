# ============================================================
# VortexTrips — Environment Variables
# Copy to .env.local and fill in real values for local dev.
# Production values live in Vercel Settings → Environment Variables.
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_NOTIFICATION_EMAIL=
CRON_SECRET=

# ─── Webhook security (Phase 8) ─────────────────────────────
# Public anti-bot token sent by all lead-form pages. Generate any random string.
# This is exposed to the browser — it's a deterrent, not a secret.
NEXT_PUBLIC_FORM_TOKEN=
# Bearer token Bland.ai sends with webhook callbacks. Set this in your Bland webhook config.
BLAND_WEBHOOK_SECRET=

# ─── AI Command Center ──────────────────────────────────────
# OpenRouter is the main AI gateway. Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model selection per task type. Browse models at https://openrouter.ai/models
# Defaults below are reasonable starting points — adjust to your budget/quality tradeoff.
AI_DEFAULT_MODEL=anthropic/claude-haiku-4.5
AI_CHEAP_MODEL=meta-llama/llama-3.3-70b-instruct
AI_MEDIUM_MODEL=anthropic/claude-sonnet-4.6
AI_STRONG_MODEL=anthropic/claude-opus-4-7
AI_CODING_MODEL=anthropic/claude-sonnet-4.6
AI_VERIFIER_MODEL=anthropic/claude-opus-4-7

# Budget guardrails (USD). AI router blocks new jobs when limits are hit.
AI_MONTHLY_BUDGET_LIMIT=75
AI_DAILY_BUDGET_LIMIT=5
AI_REQUIRE_HUMAN_APPROVAL=true

# Anthropic SDK is used directly (not via OpenRouter) by the verifier layer.
ANTHROPIC_API_KEY=

# OpenAI used for DALL-E + GPT image/text generation in content engine.
OPENAI_API_KEY=

# ─── Email + SMS ────────────────────────────────────────────
# Resend handles transactional email (drip sequences, quotes).
RESEND_API_KEY=

# Twilio handles SMS drip. BLOCKED in prod pending A2P TCR approval.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Voice AI ───────────────────────────────────────────────
# Bland.ai triggers a 60-second savings call on lead creation.
BLAND_API_KEY=

# ─── Social posting ─────────────────────────────────────────
# Facebook + Instagram use the same Meta Page Access Token (one token, both vars).
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
NEXT_PUBLIC_FB_APP_ID=
NEXT_PUBLIC_FB_LOGIN_CONFIG_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# YouTube OAuth (refresh token stored in Supabase site_settings, not here).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok Direct Post — Phase 14R wired the OAuth flow (callback at
# /api/auth/tiktok/callback) and the posting route (/api/automations/post-to-tiktok).
# CLIENT_KEY / CLIENT_SECRET come from the TikTok Developer Portal; required scopes
# include `user.info.basic` and `video.publish`. Tokens land in Supabase site_settings
# (tiktok_access_token / tiktok_refresh_token / tiktok_token_expires_at / tiktok_open_id).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Phase 14AM.1 — TikTok issues separate Sandbox credentials for testing
# pre-audit (including the demo video for the app review submission).
# When TIKTOK_USE_SANDBOX=true (or =1), all four TikTok touch points
# (src/lib/tiktok-oauth.ts, /api/auth/tiktok/login, /api/auth/tiktok/status,
# scripts/run-autoposter-once.js) read the *_SANDBOX variants instead.
# Default false → production behavior unchanged. Both pairs can coexist
# in Vercel env vars; flip the toggle to switch between them. Set back
# to false after the production app passes audit.
TIKTOK_USE_SANDBOX=false
TIKTOK_CLIENT_KEY_SANDBOX=
TIKTOK_CLIENT_SECRET_SANDBOX=
# Privacy level for posted videos. Defaults to SELF_ONLY when unset — the safest
# value for an unaudited app (posts visible only to the connected creator).
# Flip to PUBLIC_TO_EVERYONE once your TikTok app passes audit.
# Allowed: PUBLIC_TO_EVERYONE | MUTUAL_FOLLOW_FRIENDS | FOLLOWER_OF_CREATOR | SELF_ONLY
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# Twitter/X posting was removed in Phase 14Q. The post-to-twitter route was
# deleted; no TWITTER_* env vars are read by the codebase. Historical rows
# with platform='twitter' remain in content_calendar but are read-only.

# ─── Content generation ─────────────────────────────────────
# Pexels supplies real travel photos (re-hosted in Supabase Storage) AND,
# since Phase 14AG, cinematic stock travel B-roll MP4s for TikTok / Reels
# (served directly from Pexels CDN — see fetchAndStoreVideo in
# src/lib/media-providers.ts). One key powers both endpoints.
PEXELS_API_KEY=

# HeyGen — Phase 14AG removed HeyGen from the SOCIAL CONTENT PIPELINE
# (weekly cron, generate-missing-media script, dashboard). It is still
# used ONLY by the admin SBA welcome-video feature
# (src/app/api/admin/generate-sba-video, /api/admin/sba-video-status,
# /api/cron/check-heygen-jobs) which renders the Maya avatar pitch shown
# on the public /sba page. Leave these blank if you don't use that feature.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ─── ElevenLabs (Phase 21A — cinematic YouTube pipeline) ────
# ElevenLabs powers the voiceover step of the cinematic YouTube video
# pipeline. Generates an MP3 from a script + voice id, re-hosts it in
# Supabase Storage under `audio/vo/<id>.mp3`, and writes the public URL
# to content_calendar.elevenlabs_audio_url. See src/lib/elevenlabs.ts
# and /api/admin/test-elevenlabs for the smoke test.
ELEVENLABS_API_KEY=
# Travel-narrator voice id. Browse voices at https://elevenlabs.io/voice-library
# Common public voice ids that work well for travel content:
#   Adam   — pNInz6obpgDLQRdR3sFn (deep, confident, US English)
#   Antoni — ErXwobaYiN019PkySvjV (warm, conversational, US English)
#   Rachel — 21m00Tcm4TlvDq8ikWAM (neutral female, US English)
# Paste a single voice id below. Verify it works with /api/admin/test-elevenlabs.
ELEVENLABS_VOICE_ID=

# ─── Analytics ──────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── PAUSED — Stripe (membership purchase flow not yet implemented) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
